  "keyFeatures": [
    "Custom item system with configurable actions",
    "Interactive menu builder with YAML configuration",
    "Action system with 17+ action types (commands, sounds, titles, effects)",
    "Movement items (Trident, AOTE, Grappling Hook, Enderbow)",
    "Spawn management with customizable teleportation",
    "Player visibility toggler",
    "Launchpads and double-jump mechanics",
    "Chat management (lock, clear, anti-swear)",
    "World-based feature toggling",
    "PlaceholderAPI integration",
    "BungeeCord support",
    "Database integration with HikariCP",
    "Anti-WorldDownload protection"
  ],
  "publicApiSurface": [
    "/hubbly - Main plugin command",
    "/spawn - Teleport to spawn",
    "/setspawn - Set spawn location",
    "/fly - Toggle flight mode",
    "/clearchat - Clear chat for all players",
    "/lockchat - Lock/unlock chat",
    "ActionManager - Execute and register custom actions",
    "ItemsManager - Manage custom items",
    "PlayerManager - Player data management",
    "BossBarManager - BossBar display management",
    "FileManager - Configuration file handling",
    "LocaleManager - Multi-language support",
    "StorageManager - Database operations",
    "ActionEvent - Custom action execution event",
    "hubbly.* - All permissions wildcard",
    "hubbly.command.* - Command permissions",
    "hubbly.use.* - Item usage permissions",
    "hubbly.bypass.* - Bypass protection permissions"
  ]
}
